# Alfred Prime Configuration

# Anthropic API
ANTHROPIC_API_KEY=your-api-key-here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Database
DATABASE_URL=postgresql+asyncpg://alfred:alfred@localhost:5432/alfred

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
DAEMON_SECRET_KEY=generate-a-secure-key-here

# Logging
LOG_LEVEL=INFO
